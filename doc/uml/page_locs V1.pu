@startuml PageLocs_Current_Interaction
  title Current Interaction: BookController - PageLocs - PageLocsControl - PageLocsRetriever

  participant BookController
  participant PageLocs
  participant PageLocsControl
  participant PageLocsRetriever

  == Book Opening / New Document ==
  BookController -> PageLocs : openBook(...) -> startNewDocument(epub, itemrefIndex)
  activate PageLocs
  PageLocs -> PageLocs : stopControlTask() if already running
  PageLocs -> PageLocs : checkForFormatChanges(...)
  alt Recompute required (format changed / no .locs / forced)
    PageLocs -> PageLocs : clear(), setupPagesComputation()
    PageLocs -> PageLocsControl : setup(epubFilename)
    activate PageLocsControl
    PageLocsControl -> PageLocsRetriever : setup(epubFilename)
    activate PageLocsRetriever
    PageLocs -> PageLocsControl : send START_DOCUMENT(itemrefIndex, itemrefCount)
    PageLocsControl -> PageLocsRetriever : send RETRIEVE_ITEM(firstItem)
  else Already loaded from .locs
    PageLocs -> PageLocs : completed=true (no background compute)
  end
  deactivate PageLocs

  == Background Sequential Computation ==
  loop Until all spine items are marked done
    PageLocsRetriever -> PageLocs : insert(PageId, PageInfo) for each computed page
    PageLocsRetriever -> PageLocsControl : ITEM_READY(itemref) or ASAP_READY(itemref)
    PageLocsControl -> PageLocsControl : update bitset/itemsDoneCount
    PageLocsControl -> PageLocsRetriever : requestNextItem() -> RETRIEVE_ITEM(next)
  end
  PageLocsControl -> PageLocsRetriever : COMPLETED
  PageLocsControl -> PageLocs : computationCompleted()
  PageLocs -> PageLocs : controlTaskReadyToBeStopped = true, pendingSave = true

  == User Navigation (Normal Path) ==
  BookController -> PageLocs : getNextPageId()/getPrevPageId()/getPageId()
  activate PageLocs
  alt Page already in pagesMap
    PageLocs --> BookController : return matching PageId
  else Page missing and computation not completed
    PageLocs -> PageLocs : checkAndFind() -> retrieveAsap(itemref)
    PageLocs -> PageLocsControl : GET_ASAP(itemref)
    alt Different item currently running
      PageLocsControl -> PageLocsRetriever : queue GET_ASAP(itemref)
      PageLocsRetriever -> PageLocsRetriever : abort current item at page boundary
      PageLocsRetriever -> PageLocsControl : ITEM_INTERRUPTED(previous)
      PageLocsControl -> PageLocsControl : defer interrupted item, prioritize ASAP item
      PageLocsControl -> PageLocsRetriever : GET_ASAP(itemref)
    else Same item already running
      PageLocsControl -> PageLocsControl : mark asapItemref, reply when ITEM_READY arrives
    end
    PageLocsRetriever -> PageLocs : insert(...) for target item pages
    PageLocsRetriever -> PageLocsControl : ASAP_READY(itemref)
    PageLocsControl -> PageLocs : ASAP_READY(itemref)
    PageLocs --> BookController : return PageId after map lookup retry
  end
  deactivate PageLocs

  == Stop / Switch Book ==
  BookController -> PageLocs : stopControlTask()
  activate PageLocs
  PageLocs -> PageLocsControl : STOP
  PageLocsControl -> PageLocsRetriever : requestStop() + STOP
  PageLocsRetriever --> PageLocsControl : thread exits
  PageLocsControl --> PageLocs : STOPPED
  PageLocs -> PageLocs : waitForExit(), reset controlTask
  alt pendingSave
    PageLocs -> PageLocs : save(.locs)
  end
  deactivate PageLocs
@enduml